{
	"compilerOptions": {
		"target": "esNext",
		"module": "esNext",
		"moduleResolution": "node",
		"jsx": "react",
		"esModuleInterop": true,

		"strictNullChecks": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		// "noUnusedParameters": true,

		"outDir": "out",
	},
	"files": [
		"src/main.ts",
	],
}
